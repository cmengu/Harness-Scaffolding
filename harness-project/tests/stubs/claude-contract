#!/bin/sh
# Canned claude head that OBEYS the output contract: a POSITION/ANSWER/TRAILER answer whose
# trailer parses clean. Speaks both --output-format json (block) and stream-json, and honors
# COUNCIL_STUB_SYSPROMPT so injection tests can read back the injected contract.
[ -n "$COUNCIL_STUB_ARGV" ] && printf '%s ' "$@" > "$COUNCIL_STUB_ARGV"
if [ -n "$COUNCIL_STUB_SYSPROMPT" ]; then
  prev=""
  for a in "$@"; do
    [ "$prev" = "--append-system-prompt-file" ] && [ -f "$a" ] && cat "$a" >> "$COUNCIL_STUB_SYSPROMPT"
    prev="$a"
  done
fi
if [ -n "$COUNCIL_STUB_CAPTURE" ]; then cat > "$COUNCIL_STUB_CAPTURE"; else cat > /dev/null; fi
ANSWER='=== POSITION ===\nThe moon is rock.\n=== ANSWER ===\nThe moon is made of rock.\n=== TRAILER ===\n{\"position\": \"rock\", \"confidence\": 0.8}'
for a in "$@"; do [ "$a" = "stream-json" ] && STREAM=1; done
if [ -n "$STREAM" ]; then
  echo '{"type":"system","subtype":"init"}'
  printf '{"type":"result","result":"%s","total_cost_usd":0.008,"session_id":"stub-claude-sid"}\n' "$ANSWER"
else
  printf '{"result":"%s","total_cost_usd":0.008,"session_id":"stub-claude-sid"}\n' "$ANSWER"
fi
